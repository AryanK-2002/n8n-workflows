    {
      "parameters": {
        "method": "POST",
        "url": "https://scam-antarctic-faceplate.ngrok-free.dev/api/generate",
        "sendHeaders": true,
        "specifyHeaders": "json",
        "jsonHeaders": "{\n  \"Content-Type\": \"application/json\",\n  \"ngrok-skip-browser-warning\": \"true\"\n}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n{\n  \"model\": \"llama3\",\n  \"prompt\": \"Write ONE Telegram AI news update in 1-2 clear sentences. Make it specific, factual, and understandable to someone seeing it for the first time. Include the company, lab, product, or project name if clearly present. Explain what happened and why it matters. Do not invent ownership or facts. Do not use vague headlines like 'How they're built'. Do not include notes, labels, quotes, or intro text. Keep it between 25 and 40 words. Title: \" + $json.title + \". Summary: \" + ($json.contentSnippet || \"\"),\n  \"stream\": false,\n  \"options\": {\n    \"num_predict\": 90,\n    \"temperature\": 0.1\n  }\n}\n}}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1776,
        96
      ],
      "id": "a0c761ee-2d91-4e56-8a62-ab5ec1722928",
      "name": "Generate AI Headlines",
      "notesInFlow": false
    },
    {
      "parameters": {
        "jsCode": "return items.map((item, index) => {\n  let response =\n    item.json.response ||\n    item.json.body?.response ||\n    item.json.message?.content ||\n    item.json.body?.message?.content ||\n    \"\";\n\n  response = response\n    .replace(/Here is a summary of the news in one sentence:\\s*/i, \"\")\n    .replace(/Here is the one-line sentence summary:\\s*/i, \"\")\n    .replace(/Here is a one-sentence summary:\\s*/i, \"\")\n    .replace(/Here is a Telegram AI news update:\\s*/i, \"\")\n    .replace(/\\(Note:[\\s\\S]*?\\)/gi, \"\")\n    .replace(/Note:[\\s\\S]*/gi, \"\")\n    .replace(/^[\"']|[\"']$/g, \"\")\n    .trim();\n\n  return {\n    json: {\n      telegramMessage: `🔥 AI UPDATE ${index + 1}: ${response}`\n    }\n  };\n});"
      },
