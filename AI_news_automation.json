      "id": "4e39f576-6661-42b5-9260-618ce45e5b91",
      "name": "Filter Relevant AI News"
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\nif (!staticData.sentUpdates) {\n  staticData.sentUpdates = {};\n}\n\nconst now = Date.now();\nconst oneDayAgo = now - 24 * 60 * 60 * 1000;\n\nconst freshItems = items\n  .filter(item => {\n    const dateValue = item.json.isoDate || item.json.pubDate || item.json.date;\n    if (!dateValue) return true;\n\n    const itemTime = new Date(dateValue).getTime();\n    return itemTime >= oneDayAgo;\n  })\n  .sort((a, b) => {\n    const dateA = new Date(a.json.isoDate || a.json.pubDate || 0).getTime();\n    const dateB = new Date(b.json.isoDate || b.json.pubDate || 0).getTime();\n    return dateB - dateA;\n  });\n\nconst newItems = [];\n\nfor (const item of freshItems) {\n  const uniqueId = item.json.guid || item.json.link || item.json.title;\n\n  if (!uniqueId) continue;\n\n  if (!staticData.sentUpdates[uniqueId]) {\n    staticData.sentUpdates[uniqueId] = now;\n    newItems.push(item);\n  }\n}\n\nreturn newItems.map((item, index) => {\n  return {\n    json: {\n      ...item.json,\n      updateNumber: index + 1\n    }\n  };\n});"
      },
