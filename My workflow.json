    },
    {
      "parameters": {
        "maxItems": 10
      },
      "id": "5e949b25-73e6-4f84-aab5-0d6ed90b27d9",
      "name": "Limit Before HTTP",
      "type": "n8n-nodes-base.limit",
      "typeVersion": 1,
      "position": [
        1344,
        96
      ]
    },
    {
      "parameters": {
        "jsCode": "return items.map((item, index) => {\n  let response =\n    item.json.response ||\n    item.json.body?.response ||\n    item.json.message?.content ||\n    item.json.body?.message?.content ||\n    \"\";\n\n  response = response\n    .replace(/Here is a summary of the news in one sentence:\\s*/i, \"\")\n    .replace(/Here is the one-line sentence summary:\\s*/i, \"\")\n    .replace(/Here is a one-sentence summary:\\s*/i, \"\")\n    .replace(/^[\"']|[\"']$/g, \"\")\n    .trim();\n\n  return {\n    json: {\n      telegramMessage: `🔥 AI UPDATE ${index + 1}: ${response}`\n    }\n  };\n});\n  "
      },
      "id": "30fd1a27-766b-4217-a147-81c024534e77",
