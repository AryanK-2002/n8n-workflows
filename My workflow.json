    {
      "parameters": {
        "method": "POST",
        "url": "https://scam-antarctic-faceplate.ngrok-free.dev/api/generate",
        "sendHeaders": true,
        "specifyHeaders": "json",
        "jsonHeaders": "{\n  \"Content-Type\": \"application/json\",\n  \"ngrok-skip-browser-warning\": \"true\"\n}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n{\n  \"model\": \"llama3\",\n  \"prompt\": \"Write ONE Telegram-ready AI news headline. Start with the main company, lab, product, or project name if mentioned. Make it specific, not generic. Include important numbers only if present. Do not say 'the company', 'the model', 'the filter', 'the study', or 'the approach'. Do not add intro text. Max 22 words. News title: \" + $json.title + \". News summary: \" + ($json.contentSnippet || \"\"),\n  \"stream\": false,\n  \"options\": {\n    \"num_predict\": 55,\n    \"temperature\": 0.2\n  }\n}\n}}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1568,
        96
      ],
      "id": "a0c761ee-2d91-4e56-8a62-ab5ec1722928",
      "name": "HTTP Request",
